{
  "name": "open-myrsi-org",
  "private": true,
  "version": "0.0.0",
  "license": "SEE LICENSE IN LICENCE.md",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run build:server",
    "build:server": "tsc -p tsconfig.server.json",
    "gen:types": "supabase gen types typescript --linked --schema public > lib/database.types.ts",
    "i18n:check": "node scripts/i18n-check.mjs",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit": "npm audit --omit=dev --audit-level=high",
    "start": "node dist-server/server.js"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.3.1",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-table": "^3.27.1",
    "@tiptap/extension-table-cell": "^3.27.1",
    "@tiptap/extension-table-header": "^3.27.1",
    "@tiptap/extension-table-row": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/extension-youtube": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "compression": "^1.8.1",
    "dompurify": "^3.4.11",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "html-react-parser": "^6.1.3",
    "konva": "^10.3.0",
    "livekit-client": "^2.20.0",
    "livekit-server-sdk": "^2.15.5",
    "node-cron": "^4.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-konva": "^19.2.5",
    "recharts": "^3.9.0",
    "undici": "8.5.0",
    "web-push": "3.6.7"
  },
  "overrides": {
    "undici": "8.5.0",
    "jsdom": {
      "undici": "^7.25.0"
    },
    "path-to-regexp": "8.4.2",
    "minimatch": "10.2.5",
    "ip-address": "^10.2.0"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.9.2",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
