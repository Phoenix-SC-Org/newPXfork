# ============================================================================
# myRSI (single-org, self-hosted) — environment configuration
# Copy to `.env` and fill in. Never commit your real `.env`.
# ============================================================================

# --- Runtime ---------------------------------------------------------------

NODE_ENV=production
PORT=3000

# Public origin of this deployment (no trailing slash). Used for OAuth redirect
# building, Discord deep links, and SSR metadata.

APP_URL=https://yourdomain.com

# Logger verbosity: debug | info | warn | error | silent

LOG_LEVEL=info

# --- Supabase (database + realtime) ----------------------------------------
# Project URL and keys from Supabase Dashboard → Project Settings → API.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key bypasses RLS — server-only, never expose to the client.
# Required: the server cannot reach the DB without it.

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Project JWT secret (Dashboard → Project Settings → API → JWT Secret).
# The server mints per-user realtime tokens with it so clients can subscribe
# to the PRIVATE realtime broadcast channels (live updates). Without it,
# realtime is disabled (fail-closed) — the app still works via manual
# refreshes, but live updates across browsers stop.

SUPABASE_JWT_SECRET=

# --- Security --------------------------------------------------------------
# Dedicated JWT signing secret (7-day session tokens). If unset, the server
# falls back to SUPABASE_SERVICE_ROLE_KEY. Generate: openssl rand -hex 32

JWT_SECRET=

# How many reverse-proxy hops sit in front of the app (Express `trust proxy`).
# Controls how the client IP is resolved for rate limiting + abuse blocking.
# 0 (default, SECURE) = Node is directly exposed with no proxy — use the real TCP
#     peer address, which a client cannot spoof. Safe out of the box.
# 1 = ONE reverse proxy in front (e.g. the TLS terminator from the deployment guide).
# 2+ = deeper chains (e.g. CDN -> load balancer -> app).
# Set this to your actual proxy count ONLY when you run a proxy. Too LOW behind a
# proxy makes everyone share the proxy's IP (coarse limits); too HIGH (or any value
# with no proxy) lets a client spoof X-Forwarded-For and evade IP-keyed limits.

TRUST_PROXY_HOPS=0

# Set to 1 ONLY if this origin is reachable exclusively through Cloudflare
# (Cloudflare Tunnel, or a firewall allow-listing Cloudflare IPs). The server
# will then trust the CF-Connecting-IP header for the real client IP. If the
# origin is directly reachable, leave unset — a direct caller could spoof the
# header to evade rate limits or frame another IP into the abuse blocker.

TRUST_CF_PROXY=

# REQUIRED (production): AES-256-GCM encryption at rest for admin-entered secrets
# (Discord tokens, LiveKit keys, Gemini key) stored in the `settings` table. The
# server REFUSES TO BOOT in production without it, and saving a secret fails
# closed if it is unset — secrets are never stored in plaintext.
# Generate: openssl rand -hex 32
# WARNING: once set and secrets are saved, do NOT change or remove it —
# previously-encrypted values become unrecoverable.

SECRETS_ENCRYPTION_KEY=

# --- Discord (OAuth login + bot) -------------------------------------------
# From the Discord Developer Portal (https://discord.com/developers).
# OAuth2 → add redirect:  ${APP_URL}/  (the app posts its own redirect_uri).
# These env values are the fallback source; values saved later in
# Admin → Discord settings take precedence.

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Bot token + your server (guild) ID — needed for role sync, member lookup,
# channel/event posting. Optional if you don't use Discord bot features.

DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# --- Web Push (PWA notifications) ------------------------------------------
# Generate a keypair: npx web-push generate-vapid-keys

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# --- Optional integrations -------------------------------------------------
# UEX Corp API key (Star Citizen market data), if used.

UEX_API_KEY=

# Google Gemini key for AI features (can also be set in Admin → AI settings).

GEMINI_API_KEY=

# LiveKit (voice radio). Leave blank to disable radio features.

LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-livekit-host

# StarComms (optional external voice-comms integration). Read-only status in
# V1. When STARCOMMS_ENABLED is not "true" the integration is fully inert and
# the app behaves exactly as without it.
# SECURITY: STARCOMMS_OWNER_API_KEY is an owner-scoped secret — server-only,
# never sent to the browser. Rotate it if it leaks.

STARCOMMS_ENABLED=
STARCOMMS_BASE_URL=https://your-starcomms-shard
STARCOMMS_OWNER_API_KEY=
STARCOMMS_TIMEOUT_MS=5000