{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Node16",
        "moduleResolution": "node16",
        "outDir": "./dist-server",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "allowSyntheticDefaultImports": true
    },
    "include": [
        "api/**/*",
        "lib/**/*",
        "server.ts",
        "types.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "src"
    ]
}